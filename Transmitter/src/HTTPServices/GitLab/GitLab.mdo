<?xml version="1.0" encoding="UTF-8"?>
<mdclass:HTTPService xmlns:mdclass="http://g5.1c.ru/v8/dt/metadata/mdclass" uuid="670fae95-e5d3-4f55-a705-aa3422f1a821">
  <name>GitLab</name>
  <synonym>
    <key>en</key>
    <value>GitLab-services</value>
  </synonym>
  <synonym>
    <key>ru</key>
    <value>GitLab services</value>
  </synonym>
  <comment>Сервисы GitLab</comment>
  <rootURL>gitlab</rootURL>
  <reuseSessions>AutoUse</reuseSessions>
  <sessionMaxAge>20</sessionMaxAge>
  <urlTemplates uuid="160aae0f-93ea-4931-addd-a2cfc0a3ea84">
    <name>Webhooks</name>
    <synonym>
      <key>ru</key>
      <value>Webhooks</value>
    </synonym>
    <comment>Обработка webhooks GitLab</comment>
    <template>/webhooks/{RepositoryType}/{MethodName}</template>
    <methods uuid="dac1c217-fb98-4ec1-9b24-e99a308236de">
      <name>POST</name>
      <synonym>
        <key>ru</key>
        <value>POST</value>
      </synonym>
      <comment>Обработка события &quot;push events&quot;</comment>
      <httpMethod>POST</httpMethod>
      <handler>WebhooksPOST</handler>
    </methods>
  </urlTemplates>
  <urlTemplates uuid="cf81fd6b-7e78-482c-80b4-e6d54302f156">
    <name>Status</name>
    <synonym>
      <key>en</key>
      <value>Status</value>
    </synonym>
    <synonym>
      <key>ru</key>
      <value>Статус</value>
    </synonym>
    <template>/status</template>
    <methods uuid="8cc8114d-e9b4-428a-ae5b-66f6a0659cf3">
      <name>Get</name>
      <synonym>
        <key>ru</key>
        <value>Get</value>
      </synonym>
      <handler>StatusGet</handler>
    </methods>
  </urlTemplates>
</mdclass:HTTPService>
